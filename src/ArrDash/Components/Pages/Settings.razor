    private bool _showEpisodeBadges = true;
    private bool _showMissingEpisodes = true;
    private bool _showSyncNotes = true;
    private int _defaultRecentLimit = 20;
    private RecentWindowMode _recentWindowMode = RecentWindowMode.ItemCount;
    private int _recentDays = 30;
    private AudiobookSourceMode _audiobookSource = AudiobookSourceMode.Merge;
    private TimeDisplayFormat _timeFormat = TimeDisplayFormat.Relative;
    private bool _showPlexSessions = true;
    private bool _showEmbySessions = true;
    private bool _showJellyfinSessions = true;
    private bool _hideIdleSessions;
    private bool _showServerMetrics = true;
    private string _metricsHostLabel = "";
    private string _metricsDiskPath = "";
    private int _metricsPollIntervalSeconds;
    private int _metricsGraphWindowMinutes;
    private bool _enableClickThrough = true;
    private bool _deepLinkClickThrough = true;
    private ExternalLinkTarget _externalLinkTarget = ExternalLinkTarget.NewTab;
    private MissingEpisodeClickAction _missingEpisodeClickAction = MissingEpisodeClickAction.SearchOnly;
    private bool _friendlyQualityLabels = true;
    private int _pollIntervalSeconds;
    private bool _manualRefreshOnly;
    private StatusBarMode _statusBarMode = StatusBarMode.All;
    private StartupPage _startupPage = StartupPage.Dashboard;
    private bool _autoKioskOnLoad;
    private bool _kioskHideHero = true;
    private bool _kioskLargeNowPlaying;
    private bool _kioskScreensaver;
    private int _kioskScreensaverMinutes = 5;
    private KioskRotateMode _kioskRotate = KioskRotateMode.Off;
    private int _kioskRotateSeconds = 30;
    private List<string> _panelOrder = [];
    private Dictionary<string, int?> _recentLimits = new();
    private Dictionary<string, bool> _panelHidden = new();
    private Dictionary<string, PanelViewMode> _panelViewModes = new();
    private Dictionary<string, string> _panelAccentColors = new();
    private Dictionary<string, bool> _serviceEnabled = new();
    private Dictionary<string, string> _credentialInputs = new();
    private Dictionary<string, string> _urlInputs = new();
    private HashSet<string> _revealedKeys = new();
    private HashSet<string> _testing = new();
    private IReadOnlyList<CredentialStatus> _credentialStatuses = [];
    private string _selectedServiceKey = "sonarr";
    private bool _saving;
    private bool _showSettingsHelp;
    private bool _systemIsDark;
    private System.Threading.Timer? _debounceTimer;

    private CredentialStatus? SelectedCredential =>
        _credentialStatuses.FirstOrDefault(c => c.Key == _selectedServiceKey)
        ?? _credentialStatuses.FirstOrDefault();

    private RenderFragment RenderTextColorField(bool isLightMode) => __builder =>
    {
        var value = isLightMode ? _lightTextColor : _darkTextColor;
        var presets = isLightMode ? AppearanceColorPresets.LightText : AppearanceColorPresets.DarkText;
        var defaultColor = isLightMode ? AppearanceColorPresets.DefaultLightText : AppearanceColorPresets.DefaultDarkText;
        var label = isLightMode ? "Light mode text" : "Dark mode text";
        var hint = isLightMode
            ? "Dark colours for light backgrounds."
            : "Light colours for dark backgrounds.";
        var previewBg = isLightMode ? "#f4f6fb" : "#0b1020";

        <PresetColorField Label="@label"
                          Hint="@hint"
                          Value="@value"
                          ValueChanged="@(color => OnTextColorChanged(isLightMode, color))"
                          Presets="@presets"
                          DefaultColor="@defaultColor">
            <Preview>
                <div class="appearance-text-preview" style="@($"color:{value};background:{previewBg}")">
                    <span class="appearance-text-preview-heading">Sample heading</span>
                    <span class="appearance-text-preview-body">Body text</span>
                </div>
            </Preview>
        </PresetColorField>;
    };

    private RenderFragment RenderBackgroundColorField(bool isLightMode) => __builder =>
    {
        var value = isLightMode ? _lightBackgroundColor : _darkBackgroundColor;
        var presets = isLightMode ? AppearanceColorPresets.LightBackground : AppearanceColorPresets.DarkBackground;
        var defaultColor = isLightMode ? AppearanceColorPresets.DefaultLightBackground : AppearanceColorPresets.DefaultDarkBackground;
        var label = isLightMode ? "Light background" : "Dark background";
        var hint = isLightMode
            ? "Page background in light mode."
            : "Page background in dark mode.";

        <PresetColorField Label="@label"
                          Hint="@hint"
                          Value="@value"
                          ValueChanged="@(color => OnBackgroundColorChanged(isLightMode, color))"
                          Presets="@presets"
                          DefaultColor="@defaultColor">
            <Preview>
                <div class="appearance-bg-preview" style="@($"background:{value}")"></div>
            </Preview>
        </PresetColorField>;
    };

    protected override void OnInitialized()
    {
        RefreshCredentialStatuses();
        LoadFromPrefs();
        Prefs.Changed += OnPrefsChanged;
        Secrets.Changed += OnSecretsChanged;
        ThemeService.OnChange += OnSystemThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshSystemAppearanceAsync();
            StateHasChanged();
        }
    }

    private async Task RefreshSystemAppearanceAsync()
    {
        _systemIsDark = _theme switch
        {
            ThemePreference.Dark => true,
            ThemePreference.Light => false,
            _ => await ThemeService.ResolveDarkModeAsync()
        };
    }

    private async Task OnThemePreferenceChangedAsync()
    {
        await RefreshSystemAppearanceAsync();
        ScheduleLivePreviewNow();
    }

    private void OnSystemThemeChanged() => _ = InvokeAsync(async () =>
    {
        if (_theme != ThemePreference.System)
            return;

        await RefreshSystemAppearanceAsync();
        StateHasChanged();
    });

    private void LoadFromPrefs()
    {
        var prefs = Prefs.GetFormPreferences();
        _theme = prefs.Theme;
        _density = prefs.Density;
        _borderRadius = prefs.BorderRadius;
        _primaryColor = string.IsNullOrWhiteSpace(prefs.PrimaryColor)
            ? AppearanceColorPresets.DefaultAccent
            : prefs.PrimaryColor;
        _lightTextColor = string.IsNullOrWhiteSpace(prefs.LightTextColor)
            ? AppearanceColorPresets.DefaultLightText
            : prefs.LightTextColor;
        _darkTextColor = string.IsNullOrWhiteSpace(prefs.DarkTextColor)
            ? AppearanceColorPresets.DefaultDarkText
            : prefs.DarkTextColor;
        _lightBackgroundColor = string.IsNullOrWhiteSpace(prefs.LightBackgroundColor)
            ? AppearanceColorPresets.DefaultLightBackground
            : prefs.LightBackgroundColor;
        _darkBackgroundColor = string.IsNullOrWhiteSpace(prefs.DarkBackgroundColor)
            ? AppearanceColorPresets.DefaultDarkBackground
            : prefs.DarkBackgroundColor;
        _backgroundStyle = prefs.BackgroundStyle;
        _brandMark = prefs.BrandMark;
        _dashboardTitle = prefs.DashboardTitle;
        _dashboardSubtitle = prefs.DashboardSubtitle;
        _hideHeroStrip = prefs.HideHeroStrip;
        _posterSize = prefs.PosterSize;
        _posterPlacement = prefs.PosterPlacement;
        _showQuality = prefs.ShowQuality;
        _showEpisodeBadges = prefs.ShowEpisodeBadges;
        _showMissingEpisodes = prefs.ShowMissingEpisodes;
        _showSyncNotes = prefs.ShowSyncNotes;
        _defaultRecentLimit = prefs.DefaultRecentLimit;
        _recentWindowMode = prefs.RecentWindowMode;
        _recentDays = prefs.RecentDays;
        _audiobookSource = prefs.AudiobookSource;
        _timeFormat = prefs.TimeFormat;
        _showPlexSessions = prefs.ShowPlexSessions;
        _showEmbySessions = prefs.ShowEmbySessions;
        _showJellyfinSessions = prefs.ShowJellyfinSessions;
        _hideIdleSessions = prefs.HideIdleSessions;
        _showServerMetrics = prefs.ShowServerMetrics;
        _metricsHostLabel = prefs.MetricsHostLabel ?? "";
        _metricsDiskPath = prefs.MetricsDiskPath ?? "";
        _metricsPollIntervalSeconds = prefs.MetricsPollIntervalSeconds;
        _metricsGraphWindowMinutes = prefs.MetricsGraphWindowMinutes;
        _enableClickThrough = prefs.EnableClickThrough;
        _deepLinkClickThrough = prefs.DeepLinkClickThrough;
        _externalLinkTarget = prefs.ExternalLinkTarget;
        _missingEpisodeClickAction = prefs.MissingEpisodeClickAction;
        _friendlyQualityLabels = prefs.FriendlyQualityLabels;
        _pollIntervalSeconds = prefs.PollIntervalSeconds;
        _manualRefreshOnly = prefs.ManualRefreshOnly;
        _statusBarMode = prefs.StatusBarMode;
        _startupPage = prefs.StartupPage;
        _autoKioskOnLoad = prefs.AutoKioskOnLoad;
        _kioskHideHero = prefs.KioskHideHero;
        _kioskLargeNowPlaying = prefs.KioskLargeNowPlaying;
        _kioskScreensaver = prefs.KioskScreensaver;
        _kioskScreensaverMinutes = prefs.KioskScreensaverMinutes;
        _kioskRotate = prefs.KioskRotate;
        _kioskRotateSeconds = prefs.KioskRotateSeconds;
        _showSettingsHelp = prefs.ShowSettingsHelp;

        _panelOrder = prefs.PanelOrder.Count > 0 ? prefs.PanelOrder.ToList() : PanelCatalog.DefaultOrder.ToList();
        foreach (var panelId in PanelCatalog.DefaultOrder)
        {
            if (!_panelOrder.Contains(panelId))
                _panelOrder.Add(panelId);
        }

        _recentLimits = PanelCatalog.Recent.ToDictionary(
            p => p.Id,
            p => prefs.RecentLimits.TryGetValue(p.Id, out var limit) ? limit : (int?)null);

        _panelHidden = PanelCatalog.All.ToDictionary(
            p => p.Id,
            p => prefs.PanelCollapsed.TryGetValue(p.Id, out var hidden) && hidden);

        _panelViewModes = PanelCatalog.All.ToDictionary(
            p => p.Id,
            p => prefs.PanelViewModes.TryGetValue(p.Id, out var mode) ? mode : PanelViewMode.Cards);

        _panelAccentColors = PanelCatalog.All.ToDictionary(
            p => p.Id,
            p => prefs.PanelAccentColors.TryGetValue(p.Id, out var color) && !string.IsNullOrWhiteSpace(color)
                ? color
                : p.DefaultAccent);

        foreach (var cred in _credentialStatuses)
            _serviceEnabled[cred.Key] = prefs.ServiceEnabled.TryGetValue(cred.Key, out var enabled) ? enabled : true;
    }

    private void RefreshCredentialStatuses()
    {
        var configured = Secrets.GetConfiguredFlags(OptionsAccessor.Options);
        var hints = Secrets.GetMaskedHints();
        var urls = Secrets.GetCurrentUrls(OptionsAccessor.Options);
        _credentialStatuses = ServiceCredentialCatalog.BuildStatuses(configured, hints, urls);

        foreach (var cred in _credentialStatuses)
        {
            _credentialInputs.TryAdd(cred.Key, "");
            _urlInputs.TryAdd(cred.Key, "");
            _serviceEnabled.TryAdd(cred.Key, true);
        }

        if (_credentialStatuses.All(c => c.Key != _selectedServiceKey))
            _selectedServiceKey = _credentialStatuses.FirstOrDefault()?.Key ?? "sonarr";
    }

    private UserLayoutPreferences BuildFormPrefs()
    {
        var prefs = Prefs.GetFormPreferences();
        ApplyFormToPrefs(prefs);
        return prefs;
    }

    private void OnDensityChanged(LayoutDensity value) { _density = value; ScheduleLivePreviewNow(); }
    private void OnBorderRadiusChanged(BorderRadiusStyle value) { _borderRadius = value; ScheduleLivePreviewNow(); }
    private void OnBrandMarkChanged(string value) { _brandMark = value; ScheduleLivePreviewDebounced(); }

    private void OnTextColorChanged(bool isLightMode, string value)
    {
        if (isLightMode)
            _lightTextColor = value;
        else
            _darkTextColor = value;

        ScheduleLivePreviewDebounced();
    }

    private void OnBackgroundColorChanged(bool isLightMode, string value)
    {
        if (isLightMode)
            _lightBackgroundColor = value;
        else
            _darkBackgroundColor = value;

        ScheduleLivePreviewDebounced();
    }

    private void OnPanelAccentChanged(string panelId, string value)
    {
        _panelAccentColors[panelId] = value;
        ScheduleLivePreviewDebounced();
    }

    private async Task PersistShowSettingsHelpAsync() =>
        await Prefs.UpdateAsync(p => p.ShowSettingsHelp = _showSettingsHelp);

    private InputType RevealType(string key) =>
        _revealedKeys.Contains(key) ? InputType.Text : InputType.Password;

    private void ToggleReveal(string key)
    {
        if (!_revealedKeys.Add(key))
            _revealedKeys.Remove(key);
    }

    private void MovePanel(int index, int delta)
    {
        var target = index + delta;
        if (target < 0 || target >= _panelOrder.Count)
            return;

        (_panelOrder[index], _panelOrder[target]) = (_panelOrder[target], _panelOrder[index]);
        ScheduleLivePreviewNow();
    }

    private void SyncDraftFromForm()
    {
        var prefs = Prefs.GetFormPreferences();
        ApplyFormToPrefs(prefs);
        Prefs.SetSettingsDraft(prefs);
    }

    private void ScheduleLivePreviewDebounced()
    {
        SyncDraftFromForm();
        ScheduleLivePreview(debounce: true);
    }

    private void ScheduleLivePreviewNow()
    {
        SyncDraftFromForm();
        ScheduleLivePreview(debounce: false);
    }

    private void ScheduleLivePreview(bool debounce)
    {
        if (debounce)
        {
            _debounceTimer?.Dispose();
            _debounceTimer = new System.Threading.Timer(_ =>
                _ = InvokeAsync(PushLivePreviewAsync), null, 350, Timeout.Infinite);
            return;
        }

        _ = PushLivePreviewAsync();
    }

    private async Task PushLivePreviewAsync()
    {
        var prefs = new UserLayoutPreferences();
        ApplyFormToPrefs(prefs);
        var secretUpdates = BuildSecretUpdates();
        var hasPrefChanges = Prefs.DiffersFromSaved(prefs);
        var hasSecretChanges = HasAnySecretInput(secretUpdates);

        if (!hasPrefChanges && !hasSecretChanges)
        {
            ClearLivePreview();
            Prefs.ClearSettingsDraft();
            await RefreshService.RefreshAsync(CancellationToken.None);
            return;
        }

        Prefs.SetSettingsDraft(prefs);
        Prefs.SetPreview(prefs);
        CredentialsPreview.Set(hasSecretChanges ? secretUpdates : null);
        OptionsAccessor.Reload();
        await RefreshService.RefreshAsync(CancellationToken.None);
    }

    private void ClearLivePreview()
    {
        _debounceTimer?.Dispose();
        Prefs.ClearPreview();
        Prefs.ClearSettingsDraft();
        CredentialsPreview.Clear();
        OptionsAccessor.Reload();
    }

    private async Task PreviewDashboardAsync()
    {
        _debounceTimer?.Dispose();
        SyncDraftFromForm();
        await PushLivePreviewAsync();
        Nav.NavigateTo("/");
    }

    private ServiceTestInput BuildTestInput(string serviceKey)
    {
        _urlInputs.TryGetValue(serviceKey, out var url);
        _credentialInputs.TryGetValue(serviceKey, out var key);
        return new ServiceTestInput(
            string.IsNullOrWhiteSpace(url) ? null : url.Trim(),
            string.IsNullOrWhiteSpace(key) ? null : key.Trim());
    }

    private async Task TestConnectionAsync(string serviceKey)
    {
        _testing.Add(serviceKey);
        try
        {
            var (ok, message) = await ConnectionTester.TestAsync(serviceKey, BuildTestInput(serviceKey), CancellationToken.None);
            var label = _credentialStatuses.FirstOrDefault(c => c.Key == serviceKey)?.Label ?? serviceKey;
            Snackbar.Add($"{label}: {message}", ok ? Severity.Success : Severity.Warning);
        }
        finally
        {
            _testing.Remove(serviceKey);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var prefs = BuildFormPrefs();
            await Prefs.SaveAsync(prefs);
            await ThemeService.SetPreferenceAsync(_theme);
            CredentialsPreview.Clear();

            var secretUpdates = BuildSecretUpdates();
            if (HasAnySecretInput(secretUpdates))
            {
                await Secrets.SavePartialAsync(secretUpdates);
                OptionsAccessor.Reload();
            }

            await RefreshService.RefreshAsync(CancellationToken.None);

            foreach (var key in _credentialInputs.Keys.ToList())
                _credentialInputs[key] = "";
            foreach (var key in _urlInputs.Keys.ToList())
                _urlInputs[key] = "";

            RefreshCredentialStatuses();
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void ApplyFormToPrefs(UserLayoutPreferences p)
    {
        p.Theme = _theme;
        p.Density = _density;
        p.BorderRadius = _borderRadius;
        var accent = ThemeBuilder.NormalizeColor(_primaryColor.Trim(), AppearanceColorPresets.DefaultAccent);
        p.PrimaryColor = accent;
        p.SecondaryColor = ThemeBuilder.DeriveSecondaryColor(accent);
        p.GradientStartColor = accent;
        p.GradientEndColor = ThemeBuilder.DeriveSecondaryColor(accent);
        p.LightTextColor = ThemeBuilder.NormalizeColor(_lightTextColor.Trim(), AppearanceColorPresets.DefaultLightText);
        p.DarkTextColor = ThemeBuilder.NormalizeColor(_darkTextColor.Trim(), AppearanceColorPresets.DefaultDarkText);
        p.LightBackgroundColor = ThemeBuilder.NormalizeColor(_lightBackgroundColor.Trim(), AppearanceColorPresets.DefaultLightBackground);
        p.DarkBackgroundColor = ThemeBuilder.NormalizeColor(_darkBackgroundColor.Trim(), AppearanceColorPresets.DefaultDarkBackground);
        p.BackgroundStyle = _backgroundStyle;
        p.BrandMark = string.IsNullOrWhiteSpace(_brandMark) ? "A" : _brandMark.Trim()[..Math.Min(3, _brandMark.Trim().Length)];
        p.DashboardTitle = _dashboardTitle.Trim();
        p.DashboardSubtitle = _dashboardSubtitle.Trim();
        p.HideHeroStrip = _hideHeroStrip;
        p.PosterSize = _posterSize;
        p.PosterPlacement = _posterPlacement;
        p.ShowQuality = _showQuality;
        p.ShowEpisodeBadges = _showEpisodeBadges;
        p.ShowMissingEpisodes = _showMissingEpisodes;
        p.ShowSyncNotes = _showSyncNotes;
        p.DefaultRecentLimit = Math.Clamp(_defaultRecentLimit, 5, 100);
        p.RecentWindowMode = _recentWindowMode;
        p.RecentDays = Math.Clamp(_recentDays, 1, 365);
        p.AudiobookSource = _audiobookSource;
        p.TimeFormat = _timeFormat;
        p.ShowPlexSessions = _showPlexSessions;
        p.ShowEmbySessions = _showEmbySessions;
        p.ShowJellyfinSessions = _showJellyfinSessions;
        p.HideIdleSessions = _hideIdleSessions;
        p.ShowServerMetrics = _showServerMetrics;
        p.MetricsHostLabel = _metricsHostLabel.Trim();
        p.MetricsDiskPath = _metricsDiskPath.Trim();
        p.MetricsPollIntervalSeconds = Math.Clamp(_metricsPollIntervalSeconds, 0, 60);
        p.MetricsGraphWindowMinutes = Math.Clamp(_metricsGraphWindowMinutes, 0, 240);
        p.EnableClickThrough = _enableClickThrough;
        p.DeepLinkClickThrough = _deepLinkClickThrough;
        p.ExternalLinkTarget = _externalLinkTarget;
        p.MissingEpisodeClickAction = _missingEpisodeClickAction;
        p.FriendlyQualityLabels = _friendlyQualityLabels;
        p.PollIntervalSeconds = Math.Clamp(_pollIntervalSeconds, 0, 3600);
        p.ManualRefreshOnly = _manualRefreshOnly;
        p.StatusBarMode = _statusBarMode;
        p.StartupPage = _startupPage;
        p.AutoKioskOnLoad = _autoKioskOnLoad;
        p.KioskHideHero = _kioskHideHero;
        p.KioskLargeNowPlaying = _kioskLargeNowPlaying;
        p.KioskScreensaver = _kioskScreensaver;
        p.KioskScreensaverMinutes = Math.Clamp(_kioskScreensaverMinutes, 1, 120);
        p.KioskRotate = _kioskRotate;
        p.KioskRotateSeconds = Math.Clamp(_kioskRotateSeconds, 5, 300);
        p.PanelOrder = _panelOrder.ToList();
        p.RecentLimits = _recentLimits.Where(kv => kv.Value is > 0).ToDictionary(kv => kv.Key, kv => Math.Clamp(kv.Value!.Value, 5, 100));
        p.PanelCollapsed = _panelHidden.Where(kv => kv.Value).ToDictionary(kv => kv.Key, kv => kv.Value);
        p.PanelViewModes = new Dictionary<string, PanelViewMode>(_panelViewModes);
        p.PanelAccentColors = _panelAccentColors.ToDictionary(
            kv => kv.Key,
            kv => ThemeBuilder.NormalizeColor(kv.Value.Trim(), PanelCatalog.All.First(p => p.Id == kv.Key).DefaultAccent));
        p.ServiceEnabled = _serviceEnabled.ToDictionary(kv => kv.Key, kv => kv.Value);
        p.ShowSettingsHelp = _showSettingsHelp;
    }

    private ServiceSecretsFile BuildSecretUpdates() => new()
    {
        SonarrApiKey = _credentialInputs.GetValueOrDefault("sonarr"),
        RadarrApiKey = _credentialInputs.GetValueOrDefault("radarr"),
        LidarrApiKey = _credentialInputs.GetValueOrDefault("lidarr"),
        ChaptarrApiKey = _credentialInputs.GetValueOrDefault("chaptarr"),
        AudiobookShelfApiKey = _credentialInputs.GetValueOrDefault("audiobookshelf"),
        SlskdApiKey = _credentialInputs.GetValueOrDefault("slskd"),
        PlexToken = _credentialInputs.GetValueOrDefault("plex"),
        EmbyApiKey = _credentialInputs.GetValueOrDefault("emby"),
        JellyfinApiKey = _credentialInputs.GetValueOrDefault("jellyfin"),
        SonarrUrl = _urlInputs.GetValueOrDefault("sonarr"),
        RadarrUrl = _urlInputs.GetValueOrDefault("radarr"),
        LidarrUrl = _urlInputs.GetValueOrDefault("lidarr"),
        ChaptarrUrl = _urlInputs.GetValueOrDefault("chaptarr"),
        AudiobookShelfUrl = _urlInputs.GetValueOrDefault("audiobookshelf"),
        SlskdUrl = _urlInputs.GetValueOrDefault("slskd"),
        PlexUrl = _urlInputs.GetValueOrDefault("plex"),
        EmbyUrl = _urlInputs.GetValueOrDefault("emby"),
        JellyfinUrl = _urlInputs.GetValueOrDefault("jellyfin")
    };

    private static bool HasAnySecretInput(ServiceSecretsFile updates) =>
        !string.IsNullOrWhiteSpace(updates.SonarrApiKey)
        || !string.IsNullOrWhiteSpace(updates.RadarrApiKey)
        || !string.IsNullOrWhiteSpace(updates.LidarrApiKey)
        || !string.IsNullOrWhiteSpace(updates.ChaptarrApiKey)
        || !string.IsNullOrWhiteSpace(updates.AudiobookShelfApiKey)
        || !string.IsNullOrWhiteSpace(updates.SlskdApiKey)
        || !string.IsNullOrWhiteSpace(updates.PlexToken)
        || !string.IsNullOrWhiteSpace(updates.EmbyApiKey)
        || !string.IsNullOrWhiteSpace(updates.JellyfinApiKey)
        || !string.IsNullOrWhiteSpace(updates.SonarrUrl)
        || !string.IsNullOrWhiteSpace(updates.RadarrUrl)
        || !string.IsNullOrWhiteSpace(updates.LidarrUrl)
        || !string.IsNullOrWhiteSpace(updates.ChaptarrUrl)
        || !string.IsNullOrWhiteSpace(updates.AudiobookShelfUrl)
        || !string.IsNullOrWhiteSpace(updates.SlskdUrl)
        || !string.IsNullOrWhiteSpace(updates.PlexUrl)
        || !string.IsNullOrWhiteSpace(updates.EmbyUrl)
        || !string.IsNullOrWhiteSpace(updates.JellyfinUrl);

    private void Cancel()
    {
        ClearLivePreview();
        LoadFromPrefs();
        _ = RefreshService.RefreshAsync(CancellationToken.None);
        Nav.NavigateTo("/");
    }

    private void OnPrefsChanged() => _ = InvokeAsync(async () =>
    {
        if (!Prefs.IsPreviewActive)
            LoadFromPrefs();
        else if (_theme == ThemePreference.System)
            await RefreshSystemAppearanceAsync();

        StateHasChanged();
    });

    private void OnSecretsChanged() => _ = InvokeAsync(() => { RefreshCredentialStatuses(); StateHasChanged(); });

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        Prefs.Changed -= OnPrefsChanged;
        Secrets.Changed -= OnSecretsChanged;
        ThemeService.OnChange -= OnSystemThemeChanged;
    }
}
