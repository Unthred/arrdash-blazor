@page "/settings"
@inject LayoutPreferencesService Prefs
@inject ThemeService ThemeService
@inject ServiceCredentialsPreviewService CredentialsPreview
@inject ServiceSecretsStore Secrets
@inject MediaServiceOptionsAccessor OptionsAccessor
@inject DashboardRefreshService RefreshService
@inject ServiceConnectionTester ConnectionTester
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>ArrDash Settings</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="settings-page">
    <div class="settings-header-row">
        <div>
            <h1 class="settings-title">Settings</h1>
            <p class="settings-lead muted">Most layout changes apply on the dashboard — use Preview dashboard to see them before saving.</p>
        </div>
    </div>

    <div class="settings-toolbar">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving" Size="Size.Small">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Size="Size.Small">Discard</MudButton>
        <MudButton Variant="@(Prefs.IsPreviewActive ? Variant.Filled : Variant.Text)"
                   Color="@(Prefs.IsPreviewActive ? Color.Warning : Color.Default)"
                   StartIcon="@Icons.Material.Filled.Dashboard"
                   OnClick="PreviewDashboardAsync"
                   Size="Size.Small">
            Preview dashboard
        </MudButton>
        @if (Prefs.IsPreviewActive)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Unsaved — open Preview dashboard</MudChip>
        }
        <div class="settings-toolbar-spacer"></div>
        <MudSwitch @bind-Value="_showSettingsHelp"
                   @bind-Value:after="PersistShowSettingsHelpAsync"
                   Color="Color.Primary"
                   Label="Show help"
                   Class="settings-help-toggle" />
    </div>

    <CascadingValue Value="_showSettingsHelp">
    <MudTabs Class="settings-tabs" Rounded="true" ApplyEffectsToContainer="true" PanelClass="settings-tab-panel settings-tab-fit">
        <MudTabPanel Text="Layout" Icon="@Icons.Material.Filled.Dashboard">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Display</div>
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.DashboardTitle">
                        <MudTextField @bind-Value="_dashboardTitle" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Dashboard title" Variant="Variant.Outlined" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.HideHeroStrip" Class="settings-switch-cell">
                        <MudSwitch @bind-Value="_hideHeroStrip" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide hero strip" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.DashboardSubtitle" Span2="true">
                        <MudTextField @bind-Value="_dashboardSubtitle" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Subtitle" Variant="Variant.Outlined" Lines="2" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.PosterSize">
                        <MudSelect T="PosterSize" @bind-Value="_posterSize" @bind-Value:after="ScheduleLivePreviewNow" Label="Poster size" Variant="Variant.Outlined">
                            <MudSelectItem Value="PosterSize.Small">Small</MudSelectItem>
                            <MudSelectItem Value="PosterSize.Medium">Medium</MudSelectItem>
                            <MudSelectItem Value="PosterSize.Large">Large</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.PosterPlacement">
                        <MudSelect T="PosterPlacement" @bind-Value="_posterPlacement" @bind-Value:after="ScheduleLivePreviewNow" Label="Poster placement" Variant="Variant.Outlined">
                            <MudSelectItem Value="PosterPlacement.Left">Left</MudSelectItem>
                            <MudSelectItem Value="PosterPlacement.Top">Top</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowQuality">
                        <MudSwitch @bind-Value="_showQuality" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Quality labels" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowEpisodeBadges">
                        <MudSwitch @bind-Value="_showEpisodeBadges" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Episode badges" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowMissingEpisodes">
                        <MudSwitch @bind-Value="_showMissingEpisodes" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Highlight missing episodes" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowSyncNotes">
                        <MudSwitch @bind-Value="_showSyncNotes" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Audiobook sync notes" />
                    </SettingField>
                </div>
            </MudPaper>

            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Panels</div>
                <SettingSectionHelp Text="@SettingsHelpTexts.PanelOrder" />
                <div class="panel-order-compact">
                    @for (var i = 0; i < _panelOrder.Count; i++)
                    {
                        var panelId = _panelOrder[i];
                        var index = i;
                        <div class="panel-order-row">
                            <MudText Class="panel-order-label">@PanelCatalog.LabelFor(panelId)</MudText>
                            <div class="panel-order-actions">
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(index == 0)" OnClick="@(() => MovePanel(index, -1))" Size="Size.Small" />
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(index == _panelOrder.Count - 1)" OnClick="@(() => MovePanel(index, 1))" Size="Size.Small" />
                                <MudSwitch @bind-Value="_panelHidden[panelId]" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide" />
                                <MudSelect T="PanelViewMode" @bind-Value="_panelViewModes[panelId]" @bind-Value:after="ScheduleLivePreviewNow" Label="View" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Class="panel-view-select">
                                    <MudSelectItem Value="PanelViewMode.Cards">Cards</MudSelectItem>
                                    <MudSelectItem Value="PanelViewMode.Compact">List</MudSelectItem>
                                    <MudSelectItem Value="PanelViewMode.Table">Table</MudSelectItem>
                                </MudSelect>
                            </div>
                        </div>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
            <MudPaper Class="settings-section compact appearance-panel" Elevation="0">
                <div class="appearance-row appearance-row--theme">
                    <div class="appearance-section appearance-section--flat">
                        <div class="settings-section-title">Theme</div>
                        <SettingField Text="@SettingsHelpTexts.Theme">
                            <MudToggleGroup T="ThemePreference"
                                            @bind-Value="_theme"
                                            @bind-Value:after="OnThemePreferenceChangedAsync"
                                            Color="Color.Default"
                                            Rounded="true"
                                            SelectedClass="segmented-toggle-selected"
                                            Class="arrdash-segmented-toggle theme-toggle settings-theme-toggle"
                                            FixedContent>
                                <MudToggleItem Value="ThemePreference.Light" Text="Light" />
                                <MudToggleItem Value="ThemePreference.Dark" Text="Dark" />
                                <MudToggleItem Value="ThemePreference.System" Text="System" />
                            </MudToggleGroup>
                        </SettingField>
                        @if (_theme == ThemePreference.System)
                        {
                            <p class="appearance-system-hint muted">
                                Using <strong>@(_systemIsDark ? "dark" : "light")</strong> from system preference.
                            </p>
                        }
                    </div>
                </div>

                <div class="settings-grid-4 appearance-layout-row">
                    <SettingField Text="@SettingsHelpTexts.Density">
                        <MudSelect T="LayoutDensity" Value="@_density" ValueChanged="OnDensityChanged" Label="Density" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="LayoutDensity.Comfortable">Comfortable</MudSelectItem>
                            <MudSelectItem Value="LayoutDensity.Compact">Compact</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BorderRadius">
                        <MudSelect T="BorderRadiusStyle" Value="@_borderRadius" ValueChanged="OnBorderRadiusChanged" Label="Card corners" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="BorderRadiusStyle.Rounded">Rounded</MudSelectItem>
                            <MudSelectItem Value="BorderRadiusStyle.Sharp">Sharp</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BrandMark">
                        <MudTextField Value="@_brandMark" ValueChanged="@((string v) => OnBrandMarkChanged(v))" Label="Brand mark" Variant="Variant.Outlined" MaxLength="3" Margin="Margin.Dense" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BackgroundStyle">
                        <MudSelect T="BackgroundStyle" @bind-Value="_backgroundStyle" @bind-Value:after="ScheduleLivePreviewNow" Label="Background style" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="BackgroundStyle.Gradient">Gradient</MudSelectItem>
                            <MudSelectItem Value="BackgroundStyle.Solid">Solid</MudSelectItem>
                            <MudSelectItem Value="BackgroundStyle.Minimal">Minimal</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                </div>

                <div class="appearance-row appearance-row--accent">
                    <div class="appearance-color-card appearance-color-card--accent">
                        <SettingField Text="@SettingsHelpTexts.AccentColor">
                            <PresetColorField Label="Accent colour"
                                              Hint="Buttons, links, and highlights."
                                              @bind-Value="_primaryColor"
                                              @bind-Value:after="ScheduleLivePreviewDebounced"
                                              Presets="AppearanceColorPresets.Accent"
                                              DefaultColor="@AppearanceColorPresets.DefaultAccent">
                                <Preview>
                                    <div class="appearance-accent-preview">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">Sample</MudButton>
                                        <span class="appearance-accent-link">Sample link</span>
                                    </div>
                                </Preview>
                            </PresetColorField>
                        </SettingField>
                    </div>
                </div>

                @if (_theme == ThemePreference.System)
                {
                    <SettingSectionHelp Text="@SettingsHelpTexts.TextColorSystem(_systemIsDark)" />
                    <div class="appearance-mode-grid">
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.LightBackgroundColor">
                                @RenderBackgroundColorField(isLightMode: true)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.DarkBackgroundColor">
                                @RenderBackgroundColorField(isLightMode: false)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.LightTextColor">
                                @RenderTextColorField(isLightMode: true)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.DarkTextColor">
                                @RenderTextColorField(isLightMode: false)
                            </SettingField>
                        </div>
                    </div>
                }
                else
                {
                    <div class="appearance-mode-grid appearance-mode-grid--single">
                        <div class="appearance-color-card">
                            <SettingField Text="@(_theme == ThemePreference.Light ? SettingsHelpTexts.LightBackgroundColor : SettingsHelpTexts.DarkBackgroundColor)">
                                @RenderBackgroundColorField(_theme == ThemePreference.Light)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@(_theme == ThemePreference.Light ? SettingsHelpTexts.LightTextColor : SettingsHelpTexts.DarkTextColor)">
                                @RenderTextColorField(_theme == ThemePreference.Light)
                            </SettingField>
                        </div>
                    </div>
                }

                <div class="settings-section-title">Panel colours</div>
                <SettingSectionHelp Text="Accent colours used for each panel heading and highlights." />
                <div class="settings-grid-3 accent-grid">
                    @foreach (var panel in PanelCatalog.All)
                    {
                        <SettingField Text="@SettingsHelpTexts.PanelAccent(panel.Label)">
                            <ColorPickerField Label="@panel.Label"
                                              Value="@_panelAccentColors[panel.Id]"
                                              ValueChanged="@(color => OnPanelAccentChanged(panel.Id, color))"
                                              DefaultColor="@panel.DefaultAccent"
                                              AllowDefault="true" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Lists" Icon="@Icons.Material.Filled.List">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.RecentWindow">
                        <MudSelect T="RecentWindowMode" @bind-Value="_recentWindowMode" @bind-Value:after="ScheduleLivePreviewNow" Label="Recent window" Variant="Variant.Outlined">
                            <MudSelectItem Value="RecentWindowMode.ItemCount">Item count</MudSelectItem>
                            <MudSelectItem Value="RecentWindowMode.Days">Last N days</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.TimeFormat">
                        <MudSelect T="TimeDisplayFormat" @bind-Value="_timeFormat" @bind-Value:after="ScheduleLivePreviewNow" Label="Time display" Variant="Variant.Outlined">
                            <MudSelectItem Value="TimeDisplayFormat.Relative">Relative</MudSelectItem>
                            <MudSelectItem Value="TimeDisplayFormat.Clock">Clock</MudSelectItem>
                            <MudSelectItem Value="TimeDisplayFormat.DateTime">Date + time</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    @if (_recentWindowMode == RecentWindowMode.Days)
                    {
                        <SettingField Text="@SettingsHelpTexts.RecentDays">
                            <MudNumericField @bind-Value="_recentDays" @bind-Value:after="ScheduleLivePreviewNow" Label="Days" Variant="Variant.Outlined" Min="1" Max="365" />
                        </SettingField>
                    }
                    <SettingField Text="@SettingsHelpTexts.DefaultRecentLimit">
                        <MudNumericField @bind-Value="_defaultRecentLimit" @bind-Value:after="ScheduleLivePreviewNow" Label="Default list size" Variant="Variant.Outlined" Min="5" Max="100" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.AudiobookSource" Span2="true">
                        <MudSelect T="AudiobookSourceMode" @bind-Value="_audiobookSource" @bind-Value:after="ScheduleLivePreviewNow" Label="Audiobook source" Variant="Variant.Outlined">
                            <MudSelectItem Value="AudiobookSourceMode.Merge">Merge Chaptarr + ABS</MudSelectItem>
                            <MudSelectItem Value="AudiobookSourceMode.ChaptarrOnly">Chaptarr only</MudSelectItem>
                            <MudSelectItem Value="AudiobookSourceMode.AudiobookShelfOnly">AudioBookShelf only</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    @foreach (var panel in PanelCatalog.Recent)
                    {
                        <SettingField Text="@SettingsHelpTexts.PanelRecentLimit(panel.Label)">
                            <MudNumericField @bind-Value="_recentLimits[panel.Id]"
                                             @bind-Value:after="ScheduleLivePreviewNow"
                                             Label="@panel.Label"
                                             Variant="Variant.Outlined"
                                             Min="5"
                                             Max="100"
                                             Disabled="@(_recentWindowMode == RecentWindowMode.Days)" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Playback" Icon="@Icons.Material.Filled.PlayCircle">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <div class="settings-field-stack">
                        <SettingField Text="@SettingsHelpTexts.ShowPlexSessions">
                            <MudSwitch @bind-Value="_showPlexSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Plex sessions" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.ShowEmbySessions">
                            <MudSwitch @bind-Value="_showEmbySessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Emby sessions" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.ShowJellyfinSessions">
                            <MudSwitch @bind-Value="_showJellyfinSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Jellyfin sessions" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.HideIdleSessions">
                            <MudSwitch @bind-Value="_hideIdleSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide idle (0%)" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.ShowServerMetrics">
                            <MudSwitch @bind-Value="_showServerMetrics" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show server CPU, memory & disk" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.MetricsPollInterval">
                            <MudNumericField @bind-Value="_metricsPollIntervalSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Server metrics interval (sec)" Variant="Variant.Outlined" Min="0" Max="60" Disabled="@(!_showServerMetrics)" HelperText="0 = default (2 sec)" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.MetricsGraphWindow">
                            <MudNumericField @bind-Value="_metricsGraphWindowMinutes" @bind-Value:after="ScheduleLivePreviewNow" Label="CPU graph window (min)" Variant="Variant.Outlined" Min="0" Max="240" Disabled="@(!_showServerMetrics)" HelperText="0 = default (15 min)" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.MetricsHostLabel">
                            <MudTextField @bind-Value="_metricsHostLabel" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Host label" Variant="Variant.Outlined" Disabled="@(!_showServerMetrics)" Placeholder="Host" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.MetricsDiskPath">
                            <MudTextField @bind-Value="_metricsDiskPath" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Disk path(s)" Variant="Variant.Outlined" Disabled="@(!_showServerMetrics)" Placeholder="/" HelperText="Comma-separated; mount paths inside the container" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.EnableClickThrough">
                            <MudSwitch @bind-Value="_enableClickThrough" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Click-through links" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.DeepLinkClickThrough">
                            <MudSwitch @bind-Value="_deepLinkClickThrough" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Open specific item" Disabled="@(!_enableClickThrough)" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.ExternalLinkTarget">
                            <MudSelect T="ExternalLinkTarget" @bind-Value="_externalLinkTarget" @bind-Value:after="ScheduleLivePreviewNow" Label="Open links in" Variant="Variant.Outlined" Disabled="@(!_enableClickThrough)">
                                <MudSelectItem Value="ExternalLinkTarget.NewTab">New tab</MudSelectItem>
                                <MudSelectItem Value="ExternalLinkTarget.SameTab">Same tab</MudSelectItem>
                            </MudSelect>
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.MissingEpisodeClickAction">
                            <MudSelect T="MissingEpisodeClickAction" @bind-Value="_missingEpisodeClickAction" @bind-Value:after="ScheduleLivePreviewNow" Label="Missing episode click" Variant="Variant.Outlined" Disabled="@(!_showMissingEpisodes)">
                                <MudSelectItem Value="MissingEpisodeClickAction.SearchOnly">Search only</MudSelectItem>
                                <MudSelectItem Value="MissingEpisodeClickAction.OpenSonarrAndSearch">Open Sonarr and search</MudSelectItem>
                            </MudSelect>
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.FriendlyQualityLabels">
                            <MudSwitch @bind-Value="_friendlyQualityLabels" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Friendly quality labels" Disabled="@(!_showQuality)" />
                        </SettingField>
                    </div>
                    <div class="settings-field-stack">
                        <SettingField Text="@SettingsHelpTexts.PollInterval">
                            <MudNumericField @bind-Value="_pollIntervalSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Poll interval (sec)" Variant="Variant.Outlined" Min="0" Max="3600" HelperText="0 = env default" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.ManualRefreshOnly">
                            <MudSwitch @bind-Value="_manualRefreshOnly" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Manual refresh only" />
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.StatusBar">
                            <MudSelect T="StatusBarMode" @bind-Value="_statusBarMode" @bind-Value:after="ScheduleLivePreviewNow" Label="Status bar" Variant="Variant.Outlined">
                                <MudSelectItem Value="StatusBarMode.All">All services</MudSelectItem>
                                <MudSelectItem Value="StatusBarMode.OfflineOnly">Offline only</MudSelectItem>
                                <MudSelectItem Value="StatusBarMode.Hidden">Hidden</MudSelectItem>
                            </MudSelect>
                        </SettingField>
                        <SettingField Text="@SettingsHelpTexts.StartupPage">
                            <MudSelect T="StartupPage" @bind-Value="_startupPage" @bind-Value:after="ScheduleLivePreviewNow" Label="Startup page" Variant="Variant.Outlined">
                                <MudSelectItem Value="StartupPage.Dashboard">Dashboard</MudSelectItem>
                                <MudSelectItem Value="StartupPage.Settings">Settings</MudSelectItem>
                            </MudSelect>
                        </SettingField>
                    </div>
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Kiosk" Icon="@Icons.Material.Filled.Tv">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.AutoKioskOnLoad">
                        <MudSwitch @bind-Value="_autoKioskOnLoad" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Kiosk on load" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskHideHero">
                        <MudSwitch @bind-Value="_kioskHideHero" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide hero in kiosk" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskLargeNowPlaying">
                        <MudSwitch @bind-Value="_kioskLargeNowPlaying" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Large Now Playing" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskScreensaver">
                        <MudSwitch @bind-Value="_kioskScreensaver" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Screensaver when idle" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskScreensaverMinutes">
                        <MudNumericField @bind-Value="_kioskScreensaverMinutes" @bind-Value:after="ScheduleLivePreviewNow" Label="Screensaver after (min)" Variant="Variant.Outlined" Min="1" Max="120" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskRotateSeconds">
                        <MudNumericField @bind-Value="_kioskRotateSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Rotate every (sec)" Variant="Variant.Outlined" Min="5" Max="300" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskRotate" Span2="true">
                        <MudSelect T="KioskRotateMode" @bind-Value="_kioskRotate" @bind-Value:after="ScheduleLivePreviewNow" Label="Panel rotation" Variant="Variant.Outlined">
                            <MudSelectItem Value="KioskRotateMode.Off">Show all panels</MudSelectItem>
                            <MudSelectItem Value="KioskRotateMode.Sequential">Rotate panels</MudSelectItem>
                            <MudSelectItem Value="KioskRotateMode.NowPlayingOnly">Now Playing only</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Services" Icon="@Icons.Material.Filled.ToggleOn">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Enabled services</div>
                <SettingSectionHelp Text="@SettingsHelpTexts.ServicesEnabled" />
                <div class="settings-grid-2">
                    @foreach (var cred in _credentialStatuses)
                    {
                        <SettingField Text="@SettingsHelpTexts.ServiceEnabled(cred.Label)">
                            <MudSwitch @bind-Value="_serviceEnabled[cred.Key]" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="@cred.Label" Dense="true" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="API keys" Icon="@Icons.Material.Filled.Key">
            @if (SelectedCredential is { } cred)
            {
                <MudPaper Class="settings-section compact" Elevation="0">
                    <SettingField Text="@SettingsHelpTexts.ApiServicePicker" Class="mb-3">
                        <MudSelect T="string" @bind-Value="_selectedServiceKey" Label="Service" Variant="Variant.Outlined">
                            @foreach (var option in _credentialStatuses)
                            {
                                <MudSelectItem Value="@option.Key">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </SettingField>
                    <div class="credential-head mb-2">
                        <MudText Typo="Typo.subtitle1">@cred.Label</MudText>
                        <div class="credential-head-actions">
                            <MudChip T="string" Size="Size.Small" Color="@(cred.Configured ? Color.Success : Color.Default)" Variant="Variant.Outlined">
                                @(cred.Configured ? "Configured" : "Not set")
                            </MudChip>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TestConnectionAsync(cred.Key))" Disabled="@_testing.Contains(cred.Key)">
                                @(_testing.Contains(cred.Key) ? "Testing…" : "Test")
                            </MudButton>
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="muted mb-2">@cred.Instructions</MudText>
                    @if (!string.IsNullOrWhiteSpace(cred.HelpUrl))
                    {
                        <MudLink Href="@cred.HelpUrl" Target="_blank" Class="mb-2 d-block">Open @cred.Label</MudLink>
                    }
                    <SettingField Text="@SettingsHelpTexts.ApiUrl" Class="mb-2">
                        <MudTextField @bind-Value="_urlInputs[cred.Key]"
                                      @bind-Value:after="ScheduleLivePreviewDebounced"
                                      Label="URL"
                                      Variant="Variant.Outlined"
                                      Placeholder="@(cred.CurrentUrl ?? "https://service.yeradonkey.com")" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ApiKey">
                        <MudTextField @bind-Value="_credentialInputs[cred.Key]"
                                      @bind-Value:after="ScheduleLivePreviewDebounced"
                                      Label="API key / token"
                                      Variant="Variant.Outlined"
                                      Placeholder="Leave blank to use saved key"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Visibility"
                                      OnAdornmentClick="@(() => ToggleReveal(cred.Key))"
                                      InputType="@RevealType(cred.Key)" />
                    </SettingField>
                </MudPaper>
            }
        </MudTabPanel>
    </MudTabs>
    </CascadingValue>
</MudContainer>

@code {
    private ThemePreference _theme = ThemePreference.System;
    private LayoutDensity _density = LayoutDensity.Comfortable;
    private BorderRadiusStyle _borderRadius = BorderRadiusStyle.Rounded;
    private string _primaryColor = AppearanceColorPresets.DefaultAccent;
    private string _lightTextColor = AppearanceColorPresets.DefaultLightText;
    private string _darkTextColor = AppearanceColorPresets.DefaultDarkText;
    private string _lightBackgroundColor = AppearanceColorPresets.DefaultLightBackground;
    private string _darkBackgroundColor = AppearanceColorPresets.DefaultDarkBackground;
    private BackgroundStyle _backgroundStyle = BackgroundStyle.Gradient;
    private string _brandMark = "A";
    private string _dashboardTitle = "";
    private string _dashboardSubtitle = "";
    private bool _hideHeroStrip;
    private PosterSize _posterSize = PosterSize.Medium;
    private PosterPlacement _posterPlacement = PosterPlacement.Left;
