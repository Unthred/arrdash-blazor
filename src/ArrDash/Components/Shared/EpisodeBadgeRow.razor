@using ArrDash.Models
@using ArrDash.Services
@using ArrDash.Services.Clients
@inject SonarrClient Sonarr
@inject EpisodeSearchTrackerService SearchTracker
@inject LayoutPreferencesService Prefs
@inject ExternalLinkService Links
@inject MediaServiceOptionsAccessor Options
@inject ISnackbar Snackbar
@implements IDisposable

@{
    var episodes = DownloadDisplayHelper.ResolveBadgeEpisodeNumbers(Item);
    var pageEpisodes = episodes.Skip(_pageIndex * PageSize).Take(PageSize).ToList();
    var usePaging = episodes.Count > PageSize;
}

@if (episodes.Count > 0)
{
    <div class="episode-badge-row">
        <button type="button"
                class="episode-badge-arrow @(!usePaging ? "episode-badge-arrow-reserved" : null)"
                aria-label="Previous episode page"
                aria-hidden="@(!usePaging)"
                disabled="@(!usePaging || _pageIndex <= 0)"
                @onclick="PreviousPage"
                @onclick:stopPropagation="true">
            <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" />
        </button>

        <div class="episode-badge-panel">
            @foreach (var episode in pageEpisodes)
            {
                var recentEpisodes = Item.EpisodeNumbers ?? [];
                var onDiskEpisodes = Item.OnDiskEpisodeNumbers;
                var unairedEpisodes = Item.UnairedEpisodeNumbers;
                var unaired = DownloadDisplayHelper.IsUnairedEpisode(episode, unairedEpisodes);
                var missing = !unaired &&
                              DownloadDisplayHelper.IsMissingOnDisk(episode, onDiskEpisodes, recentEpisodes);
                var recent = !unaired && !missing && recentEpisodes.Contains(episode);
                var airLabel = DownloadDisplayHelper.GetEpisodeAirLabel(episode, Item.EpisodeAirDates);
                var searchStatus = Item.SeriesId is int seriesId && Item.SeasonNumber is int season && missing
                    ? SearchTracker.GetStatus(seriesId, season, episode)
                    : null;
                var searchLabel = Item.SeasonNumber is int seasonLabel
                    ? FormatEpisodeSearchLabel(seasonLabel, episode)
                    : $"E{episode:D2}";

                @if (ShowMissingEpisodes && missing && Item.SeriesId is int missingSeriesId && Item.SeasonNumber is int missingSeason)
                {
                    var activeSearch = _searchingEpisode == episode || (searchStatus?.IsActive ?? false);
                    var phaseClass = _searchingEpisode == episode && searchStatus is null
                        ? "episode-badge-phase-searching"
                        : EpisodeSearchDisplayHelper.GetPhaseClass(searchStatus?.Phase);
                    var tooltipLines = EpisodeSearchDisplayHelper.GetTooltipLines(
                        searchStatus?.Phase ?? (_searchingEpisode == episode ? EpisodeSearchPhase.Searching : null),
                        searchLabel,
                        searchStatus?.UpdatedAt,
                        Prefs.Current.MissingEpisodeClickAction);
                    var tooltipSummary = EpisodeSearchDisplayHelper.GetTooltipSummary(tooltipLines);

                    <MudTooltip Placement="Placement.Top" Arrow="true">
                        <ChildContent>
                            <span class="episode-badge-tooltip-anchor">
                                <button type="button"
                                        class="episode-badge episode-badge-missing episode-badge-action @phaseClass @(activeSearch ? "episode-badge-searching" : null)"
                                        aria-label="@tooltipSummary"
                                        disabled="@activeSearch"
                                        @onclick="() => HandleMissingEpisodeAsync(missingSeriesId, missingSeason, episode)"
                                        @onclick:stopPropagation="true">
                                    <span class="episode-badge-number">@episode</span>
                                    @if (searchStatus is not null || _searchingEpisode == episode)
                                    {
                                        <span class="episode-badge-status" aria-hidden="true">
                                            <MudIcon Icon="@(_searchingEpisode == episode && searchStatus is null
                                                              ? Icons.Material.Filled.Search
                                                              : GetPhaseIcon(searchStatus?.Phase ?? EpisodeSearchPhase.Searching))"
                                                     Size="Size.Small" />
                                        </span>
                                    }
                                </button>
                            </span>
                        </ChildContent>
                        <TooltipContent>
                            <div class="episode-badge-tooltip">
                                @foreach (var line in tooltipLines)
                                {
                                    <div>@line</div>
                                }
                            </div>
                        </TooltipContent>
                    </MudTooltip>
                }
                else if (unaired)
                {
                    <span class="episode-badge episode-badge-unaired" title="@airLabel">
                        @episode
                    </span>
                }
                else
                {
                    <span class="episode-badge @(recent ? "episode-badge-recent" : null)" title="@(recent ? "Just downloaded" : null)">
                        @episode
                    </span>
                }
            }
        </div>

        <button type="button"
                class="episode-badge-arrow @(!usePaging ? "episode-badge-arrow-reserved" : null)"
                aria-label="Next episode page"
                aria-hidden="@(!usePaging)"
                disabled="@(!usePaging || !HasNextPage)"
                @onclick="NextPage"
                @onclick:stopPropagation="true">
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
        </button>
    </div>
}

@code {
    private const int PageSize = 9;

    [Parameter, EditorRequired] public DownloadItem Item { get; set; } = default!;
    [Parameter] public bool ShowMissingEpisodes { get; set; } = true;

    private int _pageIndex;
    private string? _lastItemId;
    private int? _searchingEpisode;

    protected override void OnInitialized()
    {
        SearchTracker.StatusChanged += OnSearchStatusChanged;
    }

    private void OnSearchStatusChanged(EpisodeSearchNotification notification)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SearchTracker.StatusChanged -= OnSearchStatusChanged;
    }

    private bool HasNextPage
    {
        get
        {
            var total = DownloadDisplayHelper.ResolveBadgeEpisodeNumbers(Item).Count;
            return (_pageIndex + 1) * PageSize < total;
        }
    }

    protected override void OnParametersSet()
    {
        if (_lastItemId != Item.Id)
        {
            _pageIndex = 0;
            _lastItemId = Item.Id;
        }
    }

    private void PreviousPage()
    {
        if (_pageIndex > 0)
            _pageIndex--;
    }

    private void NextPage()
    {
        if (HasNextPage)
            _pageIndex++;
    }

    private static string GetPhaseIcon(EpisodeSearchPhase phase) => EpisodeSearchDisplayHelper.GetStatusIcon(phase) switch
    {
        "download" => Icons.Material.Filled.Download,
        "check" => Icons.Material.Filled.Check,
        "search_off" => Icons.Material.Filled.SearchOff,
        "schedule" => Icons.Material.Filled.Schedule,
        _ => Icons.Material.Filled.Search
    };

    private async Task HandleMissingEpisodeAsync(int seriesId, int seasonNumber, int episodeNumber)
    {
        if (!Prefs.IsServiceEnabled("sonarr"))
        {
            Snackbar.Add("Sonarr is disabled in settings.", Severity.Warning);
            return;
        }

        if (SearchTracker.GetStatus(seriesId, seasonNumber, episodeNumber)?.IsActive == true)
            return;

        var label = FormatEpisodeSearchLabel(seasonNumber, episodeNumber);
        var action = Prefs.Current.MissingEpisodeClickAction;

        _searchingEpisode = episodeNumber;
        StateHasChanged();

        try
        {
            if (action == MissingEpisodeClickAction.OpenSonarrAndSearch)
            {
                Snackbar.Add($"Searching Sonarr for {label}…", Severity.Info);
                var (ok, message, episodeId, commandId) = await Sonarr.SearchEpisodeAsync(seriesId, seasonNumber, episodeNumber, CancellationToken.None);
                Snackbar.Add(message, ok ? Severity.Success : Severity.Warning);

                if (ok && episodeId is int id)
                    SearchTracker.Track(new EpisodeSearchRequest(seriesId, seasonNumber, episodeNumber, id, commandId, label));

                var url = ResolveSonarrUrl();
                if (url is not null)
                    await Links.OpenAsync(url, Prefs.Current.ExternalLinkTarget);
            }
            else
            {
                Snackbar.Add($"Searching Sonarr for {label}…", Severity.Info);
                var (ok, message, episodeId, commandId) = await Sonarr.SearchEpisodeAsync(seriesId, seasonNumber, episodeNumber, CancellationToken.None);
                Snackbar.Add(ok ? $"Search queued for {label}" : message, ok ? Severity.Success : Severity.Warning);

                if (ok && episodeId is int id)
                    SearchTracker.Track(new EpisodeSearchRequest(seriesId, seasonNumber, episodeNumber, id, commandId, label));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sonarr search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _searchingEpisode = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string FormatEpisodeSearchLabel(int seasonNumber, int episodeNumber)
    {
        var episodeCode = $"S{seasonNumber:D2}E{episodeNumber:D2}";
        return string.IsNullOrWhiteSpace(Item.Title)
            ? episodeCode
            : $"{Item.Title} {episodeCode}";
    }

    private string? ResolveSonarrUrl()
    {
        if (!string.IsNullOrWhiteSpace(Item.ExternalUrl))
            return Item.ExternalUrl;

        var baseUrl = Options.Options.Sonarr.Url?.TrimEnd('/');
        return string.IsNullOrWhiteSpace(baseUrl) ? null : baseUrl;
    }
}
